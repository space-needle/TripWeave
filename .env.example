POSTGRES_DB=tripweave
POSTGRES_USER=tripweave
POSTGRES_PASSWORD=tripweave_local_password
DATABASE_URL=postgresql+psycopg://tripweave:tripweave_local_password@db:5432/tripweave
TRIPWEAVE_ENV=local
TRIPWEAVE_LOG_LEVEL=INFO
TRIPWEAVE_BLOB_DIR=/var/lib/tripweave/blobs
TRIPWEAVE_WORKER_HEARTBEAT_SECONDS=30
TRIPWEAVE_WORKER_STALE_SECONDS=90
TRIPWEAVE_SESSION_COOKIE=tripweave_session
TRIPWEAVE_CSRF_COOKIE=tripweave_csrf
TRIPWEAVE_SESSION_SECONDS=604800
TRIPWEAVE_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
TRIPWEAVE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
TRIPWEAVE_ALLOWED_WEB_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_URL=http://api:8000
