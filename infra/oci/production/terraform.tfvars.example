region           = "us-ashburn-1"
compartment_id   = "ocid1.compartment.oc1..replace"
admin_ssh_cidr   = "203.0.113.10/32"
ssh_public_key   = "ssh-ed25519 AAAA... user@example"
deployment_name  = "tripweave-mvp"
