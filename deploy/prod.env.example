# Copy to /etc/tripweave/tripweave.env on the VM, fill values, then:
# sudo chown root:root /etc/tripweave/tripweave.env
# sudo chmod 0600 /etc/tripweave/tripweave.env

POSTGRES_DB=tripweave
POSTGRES_USER=tripweave
POSTGRES_PASSWORD=replace-with-random-database-password

PUBLIC_HOST=203.0.113.10
TRIPWEAVE_SITE_ADDRESS=:80
PUBLIC_API_BASE_URL=http://203.0.113.10/api
TRIPWEAVE_ALLOWED_WEB_ORIGINS=http://203.0.113.10
TRIPWEAVE_PUBLIC_API_BASE_URL=http://203.0.113.10
ACME_EMAIL=

BLOBSTORE_BACKEND=oci
OCI_REGION=us-ashburn-1
OCI_NAMESPACE=replace-with-object-storage-namespace
OCI_STORE_ALIAS_BUCKETS=media_private=tripweave-media-private,story_published=tripweave-story-published,db_backups=tripweave-db-backups
OCI_USE_SINGLE_PUT_GRANTS=true

TRIPWEAVE_LOG_LEVEL=INFO
TRIPWEAVE_BLOB_DIR=/tmp/tripweave/blobs
TRIPWEAVE_STORAGE_SIGNING_SECRET=replace-with-random-secret-at-least-32-characters
TRIPWEAVE_SESSION_SECONDS=604800
TRIPWEAVE_GUEST_SESSION_SECONDS=604800
TRIPWEAVE_INVITATION_SECONDS=604800
TRIPWEAVE_UPLOAD_GRANT_SECONDS=900
TRIPWEAVE_UPLOAD_MAX_FILES_PER_TRIP=500
TRIPWEAVE_UPLOAD_MAX_FILE_BYTES=26214400
TRIPWEAVE_UPLOAD_MAX_TRIP_BYTES=5368709120
TRIPWEAVE_UPLOAD_ALLOWED_EXTENSIONS=.jpg,.jpeg,.heic
TRIPWEAVE_UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/heic,image/heif
TRIPWEAVE_GEOCODER_ADAPTER=nominatim
TRIPWEAVE_NOMINATIM_USER_AGENT=TripWeave-production-https://example.com
TRIPWEAVE_NOMINATIM_LANGUAGE=en
TRIPWEAVE_NOMINATIM_TIMEOUT_SECONDS=2
TRIPWEAVE_NOMINATIM_MIN_INTERVAL_SECONDS=1
TRIPWEAVE_MEDIA_MAX_PIXELS=80000000
TRIPWEAVE_MEDIA_MAX_DECODED_BYTES=536870912
TRIPWEAVE_MEDIA_THUMBNAIL_MAX_PX=480
TRIPWEAVE_MEDIA_PREVIEW_MAX_PX=1600
TRIPWEAVE_WORKER_CONCURRENCY=1
TRIPWEAVE_WORKER_POLL_SECONDS=2
NEXT_PUBLIC_TRIPWEAVE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron
